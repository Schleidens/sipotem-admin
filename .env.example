# Copy for local use (never commit real values):
#   cp .env.example .env.development   # npm run dev
#   cp .env.example .env.production    # npm run build / npm run deploy
#
# CI (GitHub Actions) injects the same VITE_* names as repository secrets.
# Do not put Firebase Admin / service-account keys here.

# Django API (no trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Firebase web client (same project as the consumer frontend)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
